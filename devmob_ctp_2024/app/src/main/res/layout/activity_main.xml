<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- Q2 : Titre "Super Taches" -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Super Tâches"
        android:textAlignment="center"
        android:textSize="48sp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="24dp" />

    <!-- Q2 : Bouton "Mes taches" → lance TacheActivity (Q5) -->
    <Button
        android:id="@+id/button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mes tâches" />

    <!-- Q2/Q3 : Bouton "Quitter" → finish() -->
    <Button
        android:id="@+id/buttonQuit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quitter" />

    <!-- Q4 : Nombre de taches a faire -->
    <TextView
        android:id="@+id/textViewTodo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:padding="4dp" />

    <!-- Q4 : Nombre de taches urgentes -->
    <TextView
        android:id="@+id/textViewUrgent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:padding="4dp" />

</LinearLayout>
