<!--
    ╔═══════════════════════════════════════════════════════════════╗
    ║  LAYOUT LOGIN - LinearLayout vertical                        ║
    ║  LIEN : LoginActivity.java → setContentView(R.layout.activity_login) ║
    ║                                                               ║
    ║  REGLES :                                                    ║
    ║  - layout_width et layout_height sont OBLIGATOIRES partout  ║
    ║  - dp = tailles/marges, sp = textes                         ║
    ║  - android:id="@+id/xxx" → accessible via R.id.xxx en Java ║
    ║  - android:onClick="xxx" → appelle la methode xxx(View) de l'Activity ║
    ╚═══════════════════════════════════════════════════════════════╝
-->
<?xml version="1.0" encoding="utf-8"?>

<!-- LinearLayout : empile les enfants verticalement (ou horizontalement) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <!-- ══ match_parent = prend toute la largeur du parent ══ -->
    <!-- ══ wrap_content = juste la taille necessaire ══ -->

    <!-- TextView : affiche du texte (pas modifiable) -->
    <TextView
        android:id="@+id/textViewTitre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Demo CTP"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="40dp" />

    <!-- EditText : champ de saisie -->
    <!-- android:inputType controle le clavier : text, number, textPassword, textEmailAddress -->
    <EditText
        android:id="@+id/editTextLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Entrez votre login"
        android:inputType="text"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp" />

    <!-- Button : android:onClick lie directement a une methode Java -->
    <!-- LoginActivity.onClickLogin(View) sera appelee au clic -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Se connecter"
        android:onClick="onClickLogin"
        android:layout_marginTop="20dp" />

    <!-- Lien vers le site (Intent implicite) -->
    <Button
        android:id="@+id/btnSiteWeb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Visiter le site IUT"
        android:onClick="onClickSiteWeb"
        android:layout_marginTop="16dp"
        style="?android:attr/borderlessButtonStyle" />

</LinearLayout>
